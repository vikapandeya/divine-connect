# ─────────────────────────────────────────────────────────────────────────────
#  PunyaSeva — Environment Variables Template
#  Copy this file to .env and fill in the values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ─── Google Gemini AI (Required for all AI features) ─────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
# NOTE: This key is used SERVER-SIDE ONLY (server.ts). It is never sent to the browser.
GEMINI_API_KEY=

# Legacy alias — only needed if older components still reference API_KEY
API_KEY=


# ─── Database Provider ───────────────────────────────────────────────────────
# Options: mysql | firebase | both
# mysql    → XAMPP MySQL only (fastest for local dev — auto-falls back to Firebase if unreachable)
# firebase → Firestore only (no MySQL needed, recommended for production)
# both     → Writes to both, reads from MySQL (good for migration)
DB_PROVIDER=mysql


# ─── MySQL Configuration (XAMPP / local dev) ─────────────────────────────────
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=divine
MYSQL_PORT=3306


# ─── Firebase / Google Cloud (for Firestore fallback & Admin SDK) ─────────────
# Leave empty to use Application Default Credentials (ADC) in Cloud environments.
# In local dev, firebase-applet-config.json is used automatically.
GOOGLE_CLOUD_PROJECT=
PROJECT_ID=


# ─── Stripe Payments ──────────────────────────────────────────────────────────
# Get your keys at: https://dashboard.stripe.com/apikeys
# If blank, Stripe runs in demo mode (no real charges).
STRIPE_SECRET_KEY=
# Public key (safe to expose to browser via VITE_ prefix if needed)
VITE_STRIPE_PUBLIC_KEY=


# ─── WhatsApp Business ────────────────────────────────────────────────────────
# Your WhatsApp business number in international format (e.g. +919876543210)
VITE_WHATSAPP_NUMBER=


# ─── Email / SMTP (for contact form & notifications) ─────────────────────────
# Required for /api/inquiry contact form emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@punyaseva.in


# ─── CORS Allowed Origins (Production) ───────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
# Leave empty in local dev — localhost:3000 and localhost:5173 are always allowed.
# Example: ALLOWED_ORIGINS=https://punyaseva.in,https://www.punyaseva.in
ALLOWED_ORIGINS=


# ─── Firebase Cloud Messaging (Push Notifications) ───────────────────────────
# Get from Firebase Console → Project Settings → Cloud Messaging
VITE_FIREBASE_VAPID_KEY=


# ─── Razorpay (Alternative payment gateway — optional) ───────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=


# ─── App Config ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
