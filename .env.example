# Environment Variables Example
# Copy this file to .env and fill in the values.
# Do NOT commit real secrets to the repository.

# --- General / App ---
API_KEY=

# --- Firebase (optional) ---
# If using Firebase, copy values from firebase-applet-config.json
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# --- Gemini / LLM provider ---
GEMINI_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Vite / Client-side env (prefix with VITE_) ---
VITE_GA_ID=
VITE_FCM_VAPID_KEY=
VITE_API_BASE_URL=

# --- MySQL Database ---
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
MYSQL_PORT=3306

# Example local development overrides (uncomment and set for local dev)
# MYSQL_HOST=127.0.0.1
# MYSQL_USER=root
# MYSQL_PASSWORD=your_local_password
# MYSQL_DATABASE=divineconnect

# After filling values, copy this file to .env and keep secrets out of git.
# cp .env.example .env
