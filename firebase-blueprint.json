{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user or devotee of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "role": { "type": "string", "enum": ["devotee", "vendor", "admin"], "description": "The user's role on the platform." },
        "phoneNumber": { "type": "string", "description": "The user's phone number." },
        "addresses": { "type": "array", "items": { "type": "string" }, "description": "List of saved addresses." },
        "bio": { "type": "string", "description": "A short bio for the user." },
        "bannerURL": { "type": "string", "description": "The user's profile banner image URL." },
        "fcmToken": { "type": "string", "description": "The user's Firebase Cloud Messaging device token." },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "description": "User's current latitude and longitude."
        },
        "vendorStatus": { "type": "string", "enum": ["none", "pending", "approved", "rejected"], "description": "The user's vendor application status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "A vendor (priest, temple, or shop owner) on the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID associated with the vendor." },
        "businessName": { "type": "string", "description": "The name of the business or temple." },
        "description": { "type": "string", "description": "A description of the vendor's services." },
        "type": { "type": "string", "enum": ["priest", "temple", "shop"], "description": "The type of vendor." },
        "status": { "type": "string", "enum": ["pending", "approved", "suspended"], "description": "The vendor's approval status." },
        "isVerified": { "type": "boolean", "description": "Whether the vendor is verified by admin." },
        "gstNumber": { "type": "string", "description": "GST registration number." },
        "rating": { "type": "number", "description": "Average rating of the vendor." },
        "commissionRate": { "type": "number", "description": "Commission rate set by admin." },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "description": "Vendor's business latitude and longitude."
        }
      },
      "required": ["uid", "businessName", "type", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "A spiritual product for sale in the marketplace.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string", "description": "The ID of the vendor selling the product." },
        "name": { "type": "string", "description": "The name of the product." },
        "description": { "type": "string", "description": "Product description." },
        "price": { "type": "number", "description": "The price of the product." },
        "category": { 
          "type": "string", 
          "enum": ["Idols", "Incense", "Mala", "Books", "Yantras", "Prasad", "Puja Essentials"],
          "description": "Standardized product category." 
        },
        "images": { "type": "array", "items": { "type": "string" }, "description": "List of product image URLs." },
        "stock": { "type": "integer", "description": "Available stock quantity." },
        "rating": { "type": "number", "description": "Average product rating." },
        "isFeatured": { "type": "boolean", "description": "Whether the product is featured on the home page." }
      },
      "required": ["vendorId", "name", "price", "category", "stock"]
    },
    "Puja": {
      "title": "Puja",
      "description": "A puja service offered by a pandit or temple.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string", "description": "The ID of the pandit or temple providing the puja." },
        "title": { "type": "string", "description": "The name of the puja." },
        "description": { "type": "string", "description": "Description of the puja and its benefits." },
        "onlinePrice": { "type": "number", "description": "Price for online puja booking." },
        "offlinePrice": { "type": "number", "description": "Price for offline puja booking." },
        "samagriList": { "type": "string", "description": "Detailed list of items required for the puja." },
        "duration": { "type": "string", "description": "Estimated duration of the puja." },
        "samagriIncluded": { "type": "boolean", "description": "Whether puja materials are included." },
        "isOnline": { "type": "boolean", "description": "Whether the puja can be performed virtually." },
        "rating": { "type": "number", "description": "Average rating of the puja service." }
      },
      "required": ["vendorId", "title", "onlinePrice"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A booking for a puja, darshan, or yatra service.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who made the booking." },
        "serviceId": { "type": "string", "description": "The ID of the puja, temple service, or yatra." },
        "vendorId": { "type": "string", "description": "The ID of the service provider." },
        "type": { "type": "string", "enum": ["puja", "darshan", "yatra"], "description": "The type of booking." },
        "isOnline": { "type": "boolean", "description": "Whether the booked service is online." },
        "bringSamagri": { "type": "boolean", "description": "Whether the user will bring their own samagri." },
        "samagriList": { "type": "string", "description": "Items included in this specific booking." },
        "date": { "type": "string", "format": "date", "description": "The date of the service." },
        "timeSlot": { "type": "string", "description": "The selected time slot." },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"], "description": "Current status of the booking." },
        "totalAmount": { "type": "number", "description": "Total price paid." },
        "paidAmount": { "type": "number", "description": "Amount paid by the user so far." },
        "travelers": { "type": "integer", "description": "Number of travelers (for yatras)." },
        "contactNumber": { "type": "string", "description": "Emergency or contact phone number." },
        "specialRequests": { "type": "string", "description": "Any special requirements for the trip." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "vendorId", "type", "date", "status", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An order for marketplace products or prasad.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who placed the order." },
        "items": { "type": "array", "description": "List of items in the order." },
        "totalAmount": { "type": "number", "description": "Total order amount." },
        "status": { "type": "string", "enum": ["processing", "shipped", "delivered", "cancelled"], "description": "Current order status." },
        "shippingAddress": { "type": "string", "description": "Delivery address." },
        "signatureURL": { "type": "string", "description": "The URL of the user's e-signature." },
        "couponUsed": { "type": "string", "description": "The coupon code used for this order." },
        "discountAmount": { "type": "number", "description": "The discount amount applied." },
        "trackingHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "message": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          },
          "description": "Historical status updates for the order."
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed." }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt"]
    },
    "Coupon": {
      "title": "Coupon",
      "description": "A discount coupon for the platform.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The unique coupon code." },
        "discount": { "type": "number", "description": "The discount value." },
        "type": { "type": "string", "enum": ["percentage", "fixed"], "description": "The type of discount." },
        "minPurchase": { "type": "number", "description": "Minimum purchase required to use the coupon." },
        "expiry": { "type": "string", "format": "date-time", "description": "When the coupon expires." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the coupon was created." }
      },
      "required": ["code", "discount", "type", "expiry"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and testimonials.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the user providing feedback." },
        "city": { "type": "string", "description": "The user's city." },
        "rating": { "type": "number", "description": "Rating given by the user." },
        "message": { "type": "string", "description": "The feedback message." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the feedback was submitted." }
      },
      "required": ["name", "rating", "message", "createdAt"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "A user's wishlist of products or pujas.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "itemId": { "type": "string", "description": "The ID of the product or puja." },
        "type": { "type": "string", "enum": ["product", "puja"], "description": "The type of item." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When it was added to wishlist." }
      },
      "required": ["userId", "itemId", "type"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "title": { "type": "string", "description": "Notification title." },
        "message": { "type": "string", "description": "Notification message." },
        "type": { "type": "string", "enum": ["order", "booking", "system"], "description": "Type of notification." },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the notification was created." }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "WhatsAppBooking": {
      "title": "WhatsApp Booking",
      "description": "A booking request for a panditji via WhatsApp.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user requesting the booking." },
        "vendorId": { "type": "string", "description": "The ID of the panditji." },
        "pujaTitle": { "type": "string", "description": "The name of the puja." },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Approval status by admin." },
        "userLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "distance": { "type": "number", "description": "Distance between user and panditji in km." },
        "whatsappNumber": { "type": "string", "description": "Panditji's WhatsApp number." },
        "totalAmount": { "type": "number", "description": "Total price for the puja." },
        "paidAmount": { "type": "number", "description": "Amount paid by the user." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "vendorId", "pujaTitle", "status", "createdAt"]
    },
    "VendorWallet": {
      "title": "Vendor Wallet",
      "description": "Wallet information for a vendor.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "balance": { "type": "number" },
        "totalEarned": { "type": "number" }
      },
      "required": ["vendorId", "balance", "totalEarned"]
    },
    "VendorPayout": {
      "title": "Vendor Payout",
      "description": "A payout request from a vendor.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "bankDetails": {
          "type": "object",
          "properties": {
            "accountNumber": { "type": "string" },
            "ifscCode": { "type": "string" },
            "accountHolderName": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vendorId", "amount", "status", "bankDetails", "createdAt"]
    },
    "VendorTransaction": {
      "title": "Vendor Transaction",
      "description": "A transaction record for a vendor wallet.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["earning", "payout"] },
        "referenceId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["vendorId", "amount", "type", "createdAt"]
    },
    "Yatra": {
      "title": "Yatra",
      "description": "A pilgrimage yatra package.",
      "type": "object",
      "properties": {
        "vendorId": { "type": "string", "description": "The ID of the vendor providing the yatra." },
        "title": { "type": "string", "description": "The name of the yatra package." },
        "description": { "type": "string", "description": "Description of the yatra." },
        "price": { "type": "number", "description": "Price per person." },
        "duration": { "type": "string", "description": "Duration of the trip (e.g., 5 Days / 4 Nights)." },
        "location": { "type": "string", "description": "Primary location or starting point." },
        "images": { "type": "array", "items": { "type": "string" }, "description": "URLs of yatra images." },
        "itinerary": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "integer" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "included": { "type": "array", "items": { "type": "string" } },
        "excluded": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "rating": { "type": "number" }
      },
      "required": ["vendorId", "title", "price", "duration", "location"]
    },
    "NaamJap": {
      "title": "Naam Jap",
      "description": "User's meditation counts for specific mantras.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "mantraId": { "type": "string" },
        "mantraName": { "type": "string" },
        "count": { "type": "integer" },
        "target": { "type": "integer" },
        "date": { "type": "string", "format": "date" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "mantraName", "count", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles." },
    "/vendors/{vendorId}": { "schema": "Vendor", "description": "Vendor details and status." },
    "/products/{productId}": { "schema": "Product", "description": "Marketplace products." },
    "/pujas/{pujaId}": { "schema": "Puja", "description": "Available puja services." },
    "/bookings/{bookingId}": { "schema": "Booking", "description": "Service bookings." },
    "/orders/{orderId}": { "schema": "Order", "description": "Marketplace and prasad orders." },
    "/feedback/{feedbackId}": { "schema": "Feedback", "description": "User feedback." },
    "/coupons/{couponId}": { "schema": "Coupon", "description": "Discount coupons." },
    "/wishlist/{wishlistId}": { "schema": "Wishlist", "description": "User wishlists." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications." },
    "/whatsapp_bookings/{bookingId}": { "schema": "WhatsAppBooking", "description": "WhatsApp booking requests." },
    "/vendor_wallets/{vendorId}": { "schema": "VendorWallet", "description": "Vendor wallet balances." },
    "/vendor_payouts/{payoutId}": { "schema": "VendorPayout", "description": "Vendor payout requests." },
    "/vendor_transactions/{transactionId}": { "schema": "VendorTransaction", "description": "Vendor wallet transactions." },
    "/yatras/{yatraId}": { "schema": "Yatra", "description": "Yatra packages." },
    "/naam_jap/{japId}": { "schema": "NaamJap", "description": "User's mantra counting progress." }
  }
}
