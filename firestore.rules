rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, format: email)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ['devotee', 'vendor', 'admin'])
    //   - createdAt: timestamp (optional)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - vendorId: string (required)
    //   - name: string (required)
    //   - description: string (optional)
    //   - price: number (required)
    //   - category: string (required)
    //   - stock: number (required)
    //   - rating: number (optional)
    //   - image: string (optional)
    //
    // Collection: pujas
    // Document ID: {pujaId}
    // Fields:
    //   - vendorId: string (required)
    //   - title: string (required)
    //   - description: string (optional)
    //   - onlinePrice: number (required)
    //   - offlinePrice: number (optional)
    //   - duration: string (optional)
    //   - samagriIncluded: bool (optional)
    //   - isOnline: bool (optional)
    //   - rating: number (optional)
    //
    // Collection: bookings
    // Document ID: {bookingId}
    // Fields:
    //   - userId: string (required)
    //   - serviceId: string (required)
    //   - vendorId: string (required)
    //   - type: string (required, enum: ['puja', 'darshan'])
    //   - date: string (required, format: date)
    //   - time: string (optional)
    //   - totalAmount: number (required)
    //   - isOnline: bool (optional)
    //   - status: string (required, enum: ['pending', 'confirmed', 'completed', 'cancelled'])
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - status: string (required)
    //   - shippingAddress: string (required)
    //   - signatureURL: string (optional)
    //   - couponUsed: string (optional)
    //   - discountAmount: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: coupons
    // Document ID: {couponId}
    // Fields:
    //   - code: string (required)
    //   - discount: number (required)
    //   - type: string (required, enum: ['percentage', 'fixed'])
    //   - minPurchase: number (optional)
    //   - expiry: timestamp (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: feedback
    // Document ID: {feedbackId}
    // Fields:
    //   - name: string (required)
    //   - city: string (optional)
    //   - rating: number (required)
    //   - message: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Collection: vendors
    // Document ID: {vendorId}
    // Fields:
    //   - uid: string (required)
    //   - businessName: string (required)
    //   - description: string (optional)
    //   - type: string (required, enum: ['priest', 'temple', 'shop'])
    //   - status: string (required, enum: ['pending', 'approved', 'suspended'])
    //   - isVerified: bool (optional)
    //   - gstNumber: string (optional)
    //   - rating: number (optional)
    //   - commissionRate: number (optional)
    //
    // Collection: wishlist
    // Document ID: {wishlistId}
    // Fields:
    //   - userId: string (required)
    //   - itemId: string (required)
    //   - type: string (required, enum: ['product', 'puja'])
    //   - createdAt: timestamp (required)
    //
    // Collection: notifications
    // Document ID: {notificationId}
    // Fields:
    //   - userId: string (required)
    //   - title: string (required)
    //   - message: string (required)
    //   - type: string (required, enum: ['order', 'booking', 'system'])
    //   - read: bool (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: whatsapp_bookings
    // Document ID: {bookingId}
    // Fields:
    //   - userId: string (required)
    //   - vendorId: string (required)
    //   - pujaTitle: string (required)
    //   - status: string (required, enum: ['pending', 'approved', 'rejected'])
    //   - userLocation: map (optional)
    //   - distance: number (optional)
    //   - whatsappNumber: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "pg2331427@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /{document=**} {
      allow read, write: if true; // TEMPORARY for debugging 403 issue
    }
  }
}
