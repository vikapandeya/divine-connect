{
  "name": "divine-connect",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "build:pages": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build --mode pages && node -e \"require('fs').copyFileSync('404.html', 'docs/404.html')\"",
    "images:generate": "node scripts/generate-spiritual-images.mjs",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "node --max-old-space-size=4096 ./node_modules/typescript/bin/tsc --noEmit",
    "firebase:emulators": "npx firebase-tools emulators:start --only functions,firestore,hosting",
    "firebase:deploy": "npx firebase-tools deploy --only functions,firestore,hosting"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.10.0",
    "framer-motion": "^12.37.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
